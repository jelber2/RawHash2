modules = ["bash", "python-3.12"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build RawHash2"

[[workflows.workflow]]
name = "Build RawHash2"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash build.sh"

[workflows.workflow.metadata]
outputType = "console"
